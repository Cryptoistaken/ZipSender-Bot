# ── Your server (.env) ────────────────────────────────────────────────────────
# These run on your 250MB Node container

BOT_TOKEN=             # Telegram bot token
OWNER_CHAT_ID=         # Your Telegram user ID (only you can use the bot)
AUNT_USERNAME=         # Telegram user ID to send files to

# GitHub — coordinator needs these to trigger Actions
GITHUB_TOKEN=          # Fine-grained PAT: Actions → Read+Write, Contents → Read
GITHUB_OWNER=          # Your GitHub username
GITHUB_REPO=           # Repo name (e.g. zipsender)
GITHUB_BRANCH=main     # Branch where worker.yml lives

# Optional: real-time callbacks from GitHub Actions to your server
# If you don't have a public URL, the bot falls back to polling every 15s
CALLBACK_URL=          # e.g. https://yourserver.com/callback  (leave empty if no public URL)
CALLBACK_PORT=         # Local port to listen on, e.g. 3001
CALLBACK_SECRET=       # Any random string for auth, e.g. mysecret123

# ── GitHub Actions secrets (set these in repo Settings → Secrets) ───────────
# DO NOT put these in this file — add them in GitHub UI

# TELEGRAM_API_ID      → from my.telegram.org
# TELEGRAM_API_HASH    → from my.telegram.org
# TELEGRAM_SESSION     → from running: npm run setup:v1
# BOT_TOKEN            → same as above
# GROQ_API_KEY         → from console.groq.com
